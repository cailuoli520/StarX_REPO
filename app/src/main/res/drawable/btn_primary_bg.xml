<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ios_blue_ripple">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="160"
                android:startColor="@color/ios_blue_light"
                android:endColor="@color/ios_blue_deep" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>
</ripple>
