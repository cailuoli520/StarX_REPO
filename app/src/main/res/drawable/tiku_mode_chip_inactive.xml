<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ios_blue_ripple">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/ios_input_top"
                android:endColor="@color/ios_input_bottom" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/ios_input_stroke" />
        </shape>
    </item>
</ripple>