<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ios_secondary_button_ripple">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/ios_secondary_button_top"
                android:endColor="@color/ios_secondary_button_bottom" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/ios_secondary_button_stroke" />
        </shape>
    </item>
</ripple>
