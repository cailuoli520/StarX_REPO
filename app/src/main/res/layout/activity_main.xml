<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <!-- ===== 顶部标题区 (iOS Large Title 风格) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/hero_panel_bg"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="20dp"
            android:paddingEnd="18dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="-0.02"
                    android:text="StarX"
                    android:textColor="@color/ios_label"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/version_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/glass_chip_bg"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="v1.2.0"
                    android:textColor="@color/ios_secondary_label"
                    android:textSize="11sp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="超星学习通增强模块"
                android:textColor="@color/ios_secondary_label"
                android:textSize="14sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/glass_chip_bg"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="Light / Dark 跟随系统 · 轻玻璃界面"
                android:textColor="@color/ios_secondary_label"
                android:textSize="11sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- ===== 模块状态 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp"
            android:text="模块状态"
            android:textAllCaps="true"
            android:textColor="@color/ios_secondary_label"
            android:textSize="13sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:elevation="0.5dp"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/status_inactive_bg"
                    android:paddingStart="14dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="5dp"
                    android:text="未连接"
                    android:textColor="@color/ios_red"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/framework_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="等待框架连接..."
                    android:textColor="@color/ios_secondary_label"
                    android:textSize="14sp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <TextView
                android:id="@+id/framework_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/ios_secondary_label"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="LSPosed v1.9.2 | API 101" />
        </LinearLayout>

        <!-- ===== 许可证激活 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp"
            android:text="许可证"
            android:textAllCaps="true"
            android:textColor="@color/ios_secondary_label"
            android:textSize="13sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:elevation="0.5dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/license_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/status_inactive_bg"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="未激活"
                android:textColor="@color/ios_red"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <EditText
                android:id="@+id/edit_activation_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/ios_input_bg"
                android:hint="输入激活码 (STARX-XXXX-XXXX-XXXX)"
                android:inputType="textCapCharacters"
                android:letterSpacing="0.05"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/btn_activate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_primary_bg"
                android:text="激活"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="⚠ 激活时需开启代理工具(VPN)，激活成功后可关闭"
                android:textColor="@color/ios_secondary_label"
                android:textSize="12sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- ===== 功能开关 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="2dp"
            android:text="功能开关"
            android:textAllCaps="true"
            android:textColor="@color/ios_secondary_label"
            android:textSize="13sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp"
            android:text="重启学习通后生效"
            android:textColor="@color/ios_tertiary_label"
            android:textSize="12sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:elevation="0.5dp"
            android:orientation="vertical">

            <!-- 反检测绕过 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="反检测绕过"
                        android:textColor="@color/ios_label"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="绕过 Root / Xposed / Magisk 检测"
                        android:textColor="@color/ios_secondary_label"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_detection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/ios_switch_thumb"
                    android:trackTint="@color/ios_switch_track"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="@color/ios_separator" />

            <!-- 广告跳过 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="广告跳过"
                        android:textColor="@color/ios_label"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="跳过开屏广告直达主页"
                        android:textColor="@color/ios_secondary_label"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_ads"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/ios_switch_thumb"
                    android:trackTint="@color/ios_switch_track"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="@color/ios_separator" />

            <!-- 签到定位 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="签到定位"
                        android:textColor="@color/ios_label"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="伪造 GPS 位置用于签到"
                        android:textColor="@color/ios_secondary_label"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_signin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/ios_switch_thumb"
                    android:trackTint="@color/ios_switch_track"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="@color/ios_separator" />

            <!-- 考试防作弊 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="考试防作弊"
                        android:textColor="@color/ios_label"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="窗口焦点 / 人脸 / 行为上报绕过"
                        android:textColor="@color/ios_secondary_label"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_anticheat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/ios_switch_thumb"
                    android:trackTint="@color/ios_switch_track"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="@color/ios_separator" />

            <!-- 小窗伪装 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="小窗伪装"
                        android:textColor="@color/ios_label"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="隐藏画中画 / 分屏状态"
                        android:textColor="@color/ios_secondary_label"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_window"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/ios_switch_thumb"
                    android:trackTint="@color/ios_switch_track"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="@color/ios_separator" />

            <!-- 视频倍速 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="视频倍速"
                        android:textColor="@color/ios_label"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="解锁 3x / 5x / 8x / 16x 播放速度"
                        android:textColor="@color/ios_secondary_label"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_video"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/ios_switch_thumb"
                    android:trackTint="@color/ios_switch_track"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="@color/ios_separator" />

            <!-- 视频时长修改 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="视频时长修改"
                        android:textColor="@color/ios_label"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="高倍速播放时自动修正后台观看时长"
                        android:textColor="@color/ios_secondary_label"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_video_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/ios_switch_thumb"
                    android:trackTint="@color/ios_switch_track"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="@color/ios_separator" />

            <!-- 答案记录 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="自动答题"
                        android:textColor="@color/ios_label"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="题库搜索 + AI 自动填写答案"
                        android:textColor="@color/ios_secondary_label"
                        android:textSize="12sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_exam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/ios_switch_thumb"
                    android:trackTint="@color/ios_switch_track"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== 签到定位设置 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="2dp"
            android:text="签到定位设置"
            android:textAllCaps="true"
            android:textColor="@color/ios_secondary_label"
            android:textSize="13sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp"
            android:text="设置伪造的 GPS 坐标和地址"
            android:textColor="@color/ios_tertiary_label"
            android:textSize="12sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:elevation="0.5dp"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edit_lat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/ios_input_bg"
                    android:hint="纬度 (如 39.9042)"
                    android:inputType="numberDecimal|numberSigned"
                    android:padding="12dp"
                    android:textColor="@color/ios_label"
                    android:textColorHint="@color/ios_tertiary_label"
                    android:textSize="14sp"
                    tools:ignore="Autofill,HardcodedText" />

                <EditText
                    android:id="@+id/edit_lng"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/ios_input_bg"
                    android:hint="经度 (如 116.4074)"
                    android:inputType="numberDecimal|numberSigned"
                    android:padding="12dp"
                    android:textColor="@color/ios_label"
                    android:textColorHint="@color/ios_tertiary_label"
                    android:textSize="14sp"
                    tools:ignore="Autofill,HardcodedText" />
            </LinearLayout>

            <EditText
                android:id="@+id/edit_addr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/ios_input_bg"
                android:hint="地址 (如 北京市东城区xx路xx号)"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/btn_pick_map"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/btn_map_secondary"
                android:text="📍 地图选点"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/btn_save_location"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_primary_bg"
                android:text="保存定位设置"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- ===== AI 答题配置 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="2dp"
            android:text="AI 答题配置"
            android:textAllCaps="true"
            android:textColor="@color/ios_secondary_label"
            android:textSize="13sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp"
            android:text="题库免费，AI 为兜底 (可选)"
            android:textColor="@color/ios_tertiary_label"
            android:textSize="12sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:elevation="0.5dp"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- OpenAI 兼容 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="OpenAI 兼容端点"
                android:textColor="@color/ios_label"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <EditText
                android:id="@+id/edit_openai_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/ios_input_bg"
                android:hint="API Key"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <EditText
                android:id="@+id/edit_openai_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/ios_input_bg"
                android:hint="Base URL (默认 api.openai.com)"
                android:inputType="textUri"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <EditText
                android:id="@+id/edit_openai_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/ios_input_bg"
                android:hint="模型 (默认 gpt-4o-mini)"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"
                android:background="@color/ios_separator" />

            <!-- Gemini -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Google Gemini"
                android:textColor="@color/ios_label"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <EditText
                android:id="@+id/edit_gemini_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/ios_input_bg"
                android:hint="Gemini API Key"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <EditText
                android:id="@+id/edit_gemini_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/ios_input_bg"
                android:hint="模型 (默认 gemini-2.0-flash)"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/btn_save_ai"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/btn_primary_bg"
                android:text="保存 AI 配置"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- ===== 柠檬题库 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp"
            android:text="柠檬题库"
            android:textAllCaps="true"
            android:textColor="@color/ios_secondary_label"
            android:textSize="13sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:elevation="0.5dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="默认已启用免费接口，填写 Token 可使用高级搜索"
                android:textColor="@color/ios_tertiary_label"
                android:textSize="12sp"
                tools:ignore="HardcodedText" />

            <EditText
                android:id="@+id/edit_lemtk_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/ios_input_bg"
                android:hint="API 地址 (留空使用默认)"
                android:inputType="textUri"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <EditText
                android:id="@+id/edit_lemtk_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/ios_input_bg"
                android:hint="Token (可选, 高级搜索需要)"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="@color/ios_label"
                android:textColorHint="@color/ios_tertiary_label"
                android:textSize="14sp"
                tools:ignore="Autofill,HardcodedText" />

            <!-- 缓存开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="本地题库缓存"
                    android:textColor="@color/ios_label"
                    android:textSize="15sp"
                    tools:ignore="HardcodedText" />

                <Switch
                    android:id="@+id/switch_cache"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:ignore="UseSwitchCompatOrMaterialSwitch" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_save_lemtk"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/btn_primary_bg"
                android:text="保存题库配置"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- ===== 操作 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="6dp"
            android:text="操作"
            android:textAllCaps="true"
            android:textColor="@color/ios_secondary_label"
            android:textSize="13sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:elevation="0.5dp"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/btn_request_scope"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/btn_primary_bg"
                android:text="请求作用域 (学习通)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/btn_join_tg"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_map_secondary"
                android:text="加入 TG 群组"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/scope_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/glass_chip_bg"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/ios_secondary_label"
                android:textSize="13sp"
                tools:text="作用域: [com.chaoxing.mobile]" />
        </LinearLayout>

        <!-- ===== 版权信息 ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="20dp"
            android:text="StarX · 仅供学习交流使用"
            android:textColor="@color/ios_tertiary_label"
            android:textSize="12sp"
            tools:ignore="HardcodedText" />

    </LinearLayout>
</ScrollView>
