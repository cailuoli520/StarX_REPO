<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/ios_input_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_template_param_query"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/tiku_mode_chip_inactive"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:text="Query"
                android:textAllCaps="false"
                android:textColor="@color/ios_label"
                android:textSize="12sp" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btn_template_param_header"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/tiku_mode_chip_inactive"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:text="Header"
                android:textAllCaps="false"
                android:textColor="@color/ios_label"
                android:textSize="12sp" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btn_template_param_body"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/tiku_mode_chip_inactive"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:text="Body"
                android:textAllCaps="false"
                android:textColor="@color/ios_label"
                android:textSize="12sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <EditText
        android:id="@+id/edit_template_param_key"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/ios_input_bg"
        android:hint="参数名 / Header 名"
        android:padding="14dp"
        android:textColor="@color/ios_label"
        android:textColorHint="@color/ios_tertiary_label" />

    <EditText
        android:id="@+id/edit_template_param_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/ios_input_bg"
        android:hint="参数值，可直接填固定值或占位符"
        android:padding="14dp"
        android:textColor="@color/ios_label"
        android:textColorHint="@color/ios_tertiary_label" />

    <Button
        android:id="@+id/btn_delete_template_param"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/btn_map_secondary"
        android:text="删除参数"
        android:textAllCaps="false"
        android:textColor="@android:color/white" />
</LinearLayout>